# ==================== CONFIGURAÇÃO MERCADO PAGO ====================
# Obtenha em: https://www.mercadopago.com.br/developers/panel

# Seu token de acesso (Access Token) - Encontre em: Painel > Credenciais > Production
MP_ACCESS_TOKEN=seu_access_token_aqui

# Sua chave pública (Public Key) - Encontre em: Painel > Credenciais > Production  
MP_PUBLIC_KEY=sua_public_key_aqui

# ==================== CONFIGURAÇÃO DO SERVIDOR ====================
# Porta que o servidor PIX vai rodar
PORT=3000

# ==================== WEBHOOKS ====================
# URL para receber confirmações de pagamento (deixe comentado se desenvolver localmente)
# WEBHOOK_URL=https://seu-dominio.com/webhook-pix
