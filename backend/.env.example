# Firebase Admin
# Option A: JSON inline (recommended for Render)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Option B: Base64 do JSON
# FIREBASE_SERVICE_ACCOUNT_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50IiwuLi59

# Option C: campos separados
# FIREBASE_PROJECT_ID=seu-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@seu-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Option D: file path (for local/dev)
FIREBASE_KEY_PATH=./src/config/firebase-key.json

# Mercado Pago
MP_ACCESS_TOKEN=SEU_ACCESS_TOKEN_AQUI
MP_PUBLIC_KEY=SUA_PUBLIC_KEY_AQUI

# Admin
ADMIN_EMAIL=admin@seu-dominio.com
ADMIN_PASSWORD=sua_senha_forte_aqui

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://zuca-personalizados.onrender.com,https://zucapersonalizados.com.br,https://www.zucapersonalizados.com.br

# Server
PORT=3000
